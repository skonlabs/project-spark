generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  fullName       String?
  avatarUrl      String?
  hashedPassword String?
  googleId       String?  @unique
  microsoftId    String?  @unique
  isActive       Boolean  @default(true)
  isVerified     Boolean  @default(false)
  isSuperuser    Boolean  @default(false)
  plan           String   @default("free")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspaceMemberships WorkspaceMember[]
}

// ─── Workspaces ───────────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  ownerId     String
  plan        String   @default("free")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  WorkspaceMember[]
  projects Project[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("viewer") // owner | admin | editor | viewer
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id                 String   @id @default(cuid())
  workspaceId        String
  name               String
  description        String?
  productName        String
  productDescription String?
  productUrl         String?
  productCategory    String?
  targetAudience     String?
  isActive           Boolean  @default(true)
  visibilityScore    Float?
  scoreBreakdown     Json?
  targetLlms         Json     @default("[]")
  monitoringPrompts  Json     @default("[]")
  settings           Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentAssets       ContentAsset[]
  contentCollections  ContentCollection[]
  analysisReports     AnalysisReport[]
  simulationJobs      SimulationJob[]
  competitors         Competitor[]
  topicNodes          TopicNode[]
  monitoringJobs      MonitoringJob[]
}

// ─── Content ──────────────────────────────────────────────────────────────────

model ContentAsset {
  id           String   @id @default(cuid())
  projectId    String
  collectionId String?
  title        String?
  sourceUrl    String?
  sourceType   String   // file_upload | url | github | crawl | sitemap
  filePath     String?
  fileType     String?
  status       String   @default("pending") // pending | processing | completed | failed
  errorMessage String?
  rawText      String?
  wordCount    Int?
  metadata     Json     @default("{}")
  tags         Json     @default("[]")
  entities     Json     @default("[]")
  topics       Json     @default("[]")
  sentiment    Float?
  isPublished  Boolean  @default(false)
  publishedUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project    Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collection ContentCollection?  @relation(fields: [collectionId], references: [id])
}

model ContentCollection {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  tags        Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assets  ContentAsset[]
}

// ─── Analysis ─────────────────────────────────────────────────────────────────

model AnalysisReport {
  id                     String   @id @default(cuid())
  projectId              String
  status                 String   @default("pending") // pending | running | completed | failed
  errorMessage           String?
  overallScore           Float?
  entityClarityScore     Float?
  categoryOwnershipScore Float?
  educationalScore       Float?
  promptCoverageScore    Float?
  comparisonScore        Float?
  ecosystemScore         Float?
  externalAuthorityScore Float?
  communitySignalScore   Float?
  consistencyScore       Float?
  structureQualityScore  Float?
  findings               Json     @default("{}")
  recommendations        Json     @default("[]")
  contentGaps            Json     @default("[]")
  promptClusters         Json     @default("{}")
  contentRoadmap         Json     @default("[]")
  taskId                 String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Simulation ───────────────────────────────────────────────────────────────

model SimulationJob {
  id           String   @id @default(cuid())
  projectId    String
  name         String?
  status       String   @default("pending") // pending | running | completed | failed
  prompts      Json     @default("[]")
  targetModels Json     @default("[]")
  summary      Json     @default("{}")
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results SimulationResult[]
}

model SimulationResult {
  id                  String   @id @default(cuid())
  jobId               String
  projectId           String
  prompt              String
  llmProvider         String
  llmModel            String
  responseText        String?
  productMentioned    Boolean?
  mentionRank         Int?
  mentionContext      String?
  sentimentScore      Float?
  confidenceScore     Float?
  entitiesMentioned   Json     @default("[]")
  competitorsMentioned Json    @default("[]")
  citations           Json     @default("[]")
  latencyMs           Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  job SimulationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ─── Competitive ──────────────────────────────────────────────────────────────

model Competitor {
  id               String   @id @default(cuid())
  projectId        String
  name             String
  websiteUrl       String?
  description      String?
  llmShareOfVoice  Float?
  avgMentionRank   Float?
  mentionFrequency Float?
  avgSentiment     Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reports CompetitiveReport[]
}

model CompetitiveReport {
  id               String   @id @default(cuid())
  competitorId     String
  projectId        String
  shareOfVoice     Float?
  mentionFrequency Float?
  avgSentiment     Float?
  promptResults    Json     @default("[]")
  dominantTopics   Json     @default("[]")
  contentGaps      Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
}

// ─── Topics ───────────────────────────────────────────────────────────────────

model TopicNode {
  id                  String   @id @default(cuid())
  projectId           String
  name                String
  slug                String
  description         String?
  parentId            String?
  depth               Int      @default(0)
  isCovered           Boolean  @default(false)
  coverageScore       Float?
  importanceScore     Float?
  competitorCoverage  Json     @default("{}")
  relatedPrompts      Json     @default("[]")
  coveringAssets      Json     @default("[]")
  graphX              Float?
  graphY              Float?
  nodeType            String   @default("core") // core | adjacent | gap
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    TopicNode?  @relation("TopicHierarchy", fields: [parentId], references: [id])
  children  TopicNode[] @relation("TopicHierarchy")
  edgesFrom TopicEdge[] @relation("EdgeSource")
  edgesTo   TopicEdge[] @relation("EdgeTarget")
}

model TopicEdge {
  id               String   @id @default(cuid())
  projectId        String
  sourceId         String
  targetId         String
  relationshipType String
  weight           Float    @default(1.0)
  createdAt        DateTime @default(now())

  sourceNode TopicNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetNode TopicNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

// ─── Monitoring ───────────────────────────────────────────────────────────────

model MonitoringJob {
  id                    String   @id @default(cuid())
  projectId             String
  name                  String
  isActive              Boolean  @default(true)
  schedule              String   @default("0 9 * * *")
  prompts               Json     @default("[]")
  targetModels          Json     @default("[]")
  lastRunAt             DateTime?
  lastRunStatus         String?
  alertOnRankDrop       Boolean  @default(true)
  alertOnNewCompetitor  Boolean  @default(true)
  rankDropThreshold     Int      @default(3)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  alerts  MonitoringAlert[]
}

model MonitoringAlert {
  id            String   @id @default(cuid())
  jobId         String
  projectId     String
  severity      String   @default("info") // info | warning | critical
  alertType     String
  title         String
  description   String?
  prompt        String?
  llmModel      String?
  previousValue Float?
  currentValue  Float?
  metadata      Json     @default("{}")
  isRead        Boolean  @default(false)
  isResolved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  job MonitoringJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ─── System Logs ──────────────────────────────────────────────────────────────

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // debug | info | warn | error
  service   String   // which service/route emitted the log
  message   String
  meta      Json     @default("{}")
  userId    String?
  projectId String?
  traceId   String?  // optional correlation ID across a request chain
  createdAt DateTime @default(now())

  @@index([level])
  @@index([service])
  @@index([projectId])
  @@index([createdAt])
}
