# =============================================================================
# GAEO Platform — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -------------------------
# Application
# -------------------------
APP_NAME="GAEO Platform"
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# -------------------------
# Database
# -------------------------
DATABASE_URL=postgresql+asyncpg://gaeo:gaeo_pass@postgres:5432/gaeo_db
DATABASE_SYNC_URL=postgresql://gaeo:gaeo_pass@postgres:5432/gaeo_db
POSTGRES_USER=gaeo
POSTGRES_PASSWORD=gaeo_pass
POSTGRES_DB=gaeo_db

# -------------------------
# Redis
# -------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -------------------------
# AI / LLM APIs
# -------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
XAI_API_KEY=your-xai-grok-api-key

# Primary LLM for platform operations
PRIMARY_LLM=claude-sonnet-4-6

# -------------------------
# Authentication
# -------------------------
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Okta
OKTA_DOMAIN=your-okta-domain.okta.com
OKTA_CLIENT_ID=your-okta-client-id
OKTA_CLIENT_SECRET=your-okta-client-secret

# -------------------------
# Storage
# -------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=gaeo-content
S3_REGION=us-east-1

# -------------------------
# Web Crawling
# -------------------------
CRAWL_MAX_PAGES=500
CRAWL_TIMEOUT_SECONDS=30
CRAWL_USER_AGENT="GAEOBot/1.0 (AI Engine Optimization Platform)"

# -------------------------
# Rate Limiting
# -------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# -------------------------
# Email (for notifications)
# -------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@gaeo.ai

# -------------------------
# Frontend (Next.js)
# -------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
