# =============================================================================
# GAEO Platform — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -------------------------
# Application
# -------------------------
APP_NAME="GAEO Platform"
APP_URL=http://localhost:3000

# -------------------------
# Database (Prisma)
# -------------------------
DATABASE_URL=postgresql://gaeo:gaeo_pass@postgres:5432/gaeo_db
POSTGRES_USER=gaeo
POSTGRES_PASSWORD=gaeo_pass
POSTGRES_DB=gaeo_db

# -------------------------
# Redis
# -------------------------
REDIS_URL=redis://redis:6379/0

# -------------------------
# AI / LLM APIs
# -------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# -------------------------
# Authentication (JWT via jose)
# -------------------------
JWT_SECRET=your-jwt-secret-key-change-in-production-min-32-chars

# -------------------------
# Storage (MinIO / S3)
# -------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=gaeo-content
S3_REGION=us-east-1

# -------------------------
# Email (optional, for notifications)
# -------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@gaeo.ai

# -------------------------
# Frontend (Next.js public vars)
# -------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
